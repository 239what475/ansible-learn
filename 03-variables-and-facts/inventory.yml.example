# 复制本文件为 inventory.yml，再按你的实际环境修改。
# 例如：cp inventory.yml.example inventory.yml

all:
  # `vars` 里的变量会被下面所有主机和组继承。
  vars:
    ansible_user: your-user
    ansible_ssh_private_key_file: ~/.ssh/id_ed25519

  # `children` 用来定义主机组，方便后续让 playbook 按组执行。
  children:
    incus_nodes:
      # `hosts` 下面列出这一组里的具体主机。
      hosts:
        node1:
          ansible_host: 192.0.2.11
        node2:
          ansible_host: 192.0.2.12
